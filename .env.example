POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/rag

BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
MAX_UPLOAD_MB=100

# OpenRouter (recommended)
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=your_openrouter_api_key_here
LLM_MODEL=google/gemma-4-31b-it:free
LLM_TIMEOUT_SEC=600

# OpenRouter embeddings (nvidia/llama-nemotron-embed-vl-1b-v2 outputs 4096-dim vectors)
EMBEDDING_API_URL=https://openrouter.ai/api/v1/embeddings
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDING_DIM=4096
EMBEDDING_TIMEOUT_SEC=600
EMBEDDING_BATCH_SIZE=8

# LM Studio on host (alternative):
# LLM_API_URL=http://host.docker.internal:1234/v1/chat/completions
# EMBEDDING_API_URL=http://host.docker.internal:1234/v1/embeddings

RAG_TOP_K=12
RAG_SEARCH_LIMIT=120
RAG_CONTEXT_BUDGET_CHARS=24000
RAG_PROMPT_MAX_CHUNK_CHARS=3500
RAG_MAX_DISTANCE=0.65
RAG_FALLBACK_ON_EMPTY=true
RAG_FALLBACK_MAX_DISTANCE=0.78
RAG_NEIGHBOR_WINDOW=1
RERANK_VECTOR_WEIGHT=0.85
RERANK_LEXICAL_WEIGHT=0.15
RERANK_MIN_LEXICAL_OVERLAP=0.0
RAG_CHUNK_SIZE=2800
RAG_CHUNK_OVERLAP=450
RAG_CHUNK_MIN_MERGE_CHARS=300

# Optimized PDF preparation: pdf text layer -> Tesseract -> VL fallback only for low-quality pages.
PREPARE_PAGE_ENGINE=auto
PREPARE_WORKERS=2
TESSERACT_LANG=rus+eng
PREPARE_VL_API_URL=https://openrouter.ai/api/v1/chat/completions
PREPARE_VL_API_KEY=your_openrouter_api_key_here
PREPARE_VL_MODEL=openrouter/owl-alpha
PREPARE_VL_TIMEOUT=600
PREPARE_VL_ZOOM=2.5
PREPARE_VL_MIN_QUALITY=2.1

AUTH_SECRET_KEY=change-me-in-production
AUTH_MODE=dev
AUTH_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000
JWT_EXPIRE_MINUTES=10080
CHAT_HISTORY_LIMIT=10
LLM_MOCK=0
